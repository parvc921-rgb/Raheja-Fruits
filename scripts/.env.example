# Same base64-encoded Firebase service account JSON used by the Next.js
# apps' Server Actions (see apps/customer/.env.example for how to
# generate it: Firebase Console > Project Settings > Service Accounts >
# Generate new private key, then base64-encode the downloaded JSON).
FIREBASE_SERVICE_ACCOUNT_KEY=

# Optional — if set, the seed script also bootstraps the very first
# super_admin account (creates the Firebase Auth user if it doesn't
# already exist, then sets admins/{uid} with role: "super_admin",
# isActive: true). Leave unset to skip this step and seed buildings/
# fruits only.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_ADMIN_PHONE=
