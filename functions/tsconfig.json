{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@raheja/shared": ["../packages/shared/src"],
      "@raheja/shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
