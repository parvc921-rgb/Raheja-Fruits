# WhatsApp Business Platform (Meta Graph API) — used by onOrderCreated
# (functions/src/notifications.ts) to send the order confirmation.
#
# Get these from Meta Business Manager > WhatsApp > API Setup:
#   WHATSAPP_ACCESS_TOKEN    — a permanent access token for a System User
#                               with whatsapp_business_messaging permission
#                               (the temporary token shown in the Meta
#                               dashboard's quickstart expires in 24h —
#                               don't use that one for anything real)
#   WHATSAPP_PHONE_NUMBER_ID — the numeric ID of the sending phone number,
#                               NOT the phone number itself
#
# Local development: put real values in functions/.env (gitignored).
# Production: set as Cloud Functions secrets rather than plain env vars,
# since this token can send messages on the business's behalf:
#   firebase functions:secrets:set WHATSAPP_ACCESS_TOKEN
#   firebase functions:secrets:set WHATSAPP_PHONE_NUMBER_ID
# then reference them in the function definition — see the note in
# README's WhatsApp setup section.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
